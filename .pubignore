# Files NOT to ship to pub.dev. Pub falls back to .gitignore by default;
# this file overrides that for files git tracks but pub shouldn't ship.

# llama.cpp submodule — users provide their own native libraries.
# Anchored with leading `/` so it doesn't also match `lib/src/`.
/src/

# Native build artifacts and build scripts. The package itself is
# pure Dart; consumers pull native artifacts from GitHub Releases
# and call `LlamaLibrary.load(path:)` against them.
/build/
/tool/

# Internal hand-off docs. Useful in the repo, noise on pub.dev.
HANDOFF.md
HANDOFF_M10.md
llama_cpp.podspec

# CI workflow definitions (not useful to package consumers).
.github/

# Editor / OS junk.
.vscode/
.idea/
*.iml
.dart_tool/
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Stray example log files.
rag_log.txt
